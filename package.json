{
  "name": "sm-365",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm --workspace apps/web run dev\" \"npm --workspace apps/api run start:dev\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test:api": "npm --workspace apps/api test -- --runInBand"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0"
  }
}
