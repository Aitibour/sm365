PROJECT_NAME=SM 365
COMPOSE_PROJECT_NAME=sm365

TRAEFIK_ACME_EMAIL=admin@sm365.local

APP_DOMAIN=app.sm365.local
API_DOMAIN=api.sm365.local
SOCIAL_DOMAIN=social.sm365.local
CRM_DOMAIN=crm.sm365.local
MARKETING_DOMAIN=marketing.sm365.local
CHAT_DOMAIN=chat.sm365.local

WEB_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_USER=sm365
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sm365

REDIS_PASSWORD=

NEXT_PUBLIC_APP_NAME=SM 365
NEXT_PUBLIC_API_BASE_URL=https://api.sm365.local
AUTH_SECRET=change-this-secret

INTERNAL_API_PORT=4000
NODE_ENV=production

MAUTIC_IMAGE=mautic/mautic:latest
TWENTY_IMAGE=twentycrm/twenty:latest
CHATWOOT_IMAGE=chatwoot/chatwoot:latest

# Postiz image/tag should be verified against the official repo docs before deployment.
POSTIZ_IMAGE=ghcr.io/gitroomhq/postiz-app:latest

# API database
DATABASE_URL=file:./data/sm365.db
